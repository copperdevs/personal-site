{
	"compilerOptions": {
		"strict": true,
		"target": "esnext",
		"noEmit": true,
		"isolatedModules": true,
		"moduleDetection": "force",
		"esModuleInterop": true,
		"module": "esnext",
		"moduleResolution": "bundler",
		"skipLibCheck": true,
		"noUncheckedIndexedAccess": true,
		"exactOptionalPropertyTypes": true,
		"jsx": "react-jsx",
		"rootDir": "src",
		"paths": {
			"@/*": ["./src/*"]
		}
	},
	"include": ["src"],
	"exclude": ["node_modules", "dist"]
}
