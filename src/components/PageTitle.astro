---
interface Props {
  pageTitle: string;
  pageLinks?: [string, string, Icon?][];
}

const { pageTitle, pageLinks } = Astro.props;

import { capitalizeFirstLetter } from "../lib/util";
import type { Icon } from "./icons/Icons.astro";
import Icons from "./icons/Icons.astro";

const currentPath = Astro.url.pathname;
---

<div class="spacer-title">
  <h1 class="no-spacing" style="display: inline-block">
    {capitalizeFirstLetter(pageTitle)}
    <h2
      class="no-spacing"
      style="display: inline-block; color: rgb(150, 150, 150); "
    >
      ​ ​ - {currentPath}
    </h2>
  </h1>
  <hr />
</div>
{
  pageLinks !== undefined && (
    <div class="pagenav">
      {pageLinks.map((link) => (
        <a href={link[1]}>
          {link[2] !== undefined && <Icons icon={link[2]} />} {link[0]}
        </a>
      ))}
      <hr />
    </div>
  )
}
