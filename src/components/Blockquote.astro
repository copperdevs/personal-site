---
interface Props {
  full?: boolean;
  noSpacing?: boolean;
  noBottomSpacing?: boolean;
  onlyBottomSpacing?: boolean;
}

const {
  full = true,
  noSpacing = false,
  noBottomSpacing = false,
  onlyBottomSpacing = false,
} = Astro.props;
---

<blockquote
  class={`${full ? "full" : ""} ${noSpacing ? "nospacing" : ""} ${noBottomSpacing ? "nobottomspacing" : ""} ${onlyBottomSpacing ? "onlybottomspacing" : ""}`}
>
  <div class="push">
    <slot />
  </div>
</blockquote>
