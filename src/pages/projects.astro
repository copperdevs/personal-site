---
import BlockquoteLink from "../components/BlockquoteLink.astro";
import QuoteLayout from "../layouts/QuoteLayout.astro";
import { getCollection } from "astro:content";

const allProjects = await getCollection("projects");
---

<QuoteLayout pageTitle="projects" description="i've made stuff perchance">
  <BlockquoteLink href="/"> Home </BlockquoteLink>
  <hr />
  {
    allProjects.map((project, index) => (
      <BlockquoteLink
        href={project.data.link}
        noSpacing={index !== 0}
        noBottomSpacing={index === 0}
      >
        {project.data.name}
      </BlockquoteLink>
    ))
  }
</QuoteLayout>
