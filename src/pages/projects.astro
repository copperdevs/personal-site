---
import BlockquoteLink from "../components/BlockquoteLink.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";

const allProjects = await getCollection("projects");
---

<BaseLayout pageTitle="projects" description="i've made stuff perchance">
  <BlockquoteLink href="/"> Home </BlockquoteLink>
  <hr />
  {
    allProjects.map((project) => (
      <BlockquoteLink href={project.data.link}>
        {project.data.name}
      </BlockquoteLink>
    ))
  }
</BaseLayout>
