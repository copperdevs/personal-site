---
const { id } = Astro.params;
import { Socials } from "../../variables";

export function getStaticPaths() {
  let paths = [{ params: { id: "404" } }];

  for (const value of Object.keys(Socials)) {
    paths.push({ params: { id: value } });
  }

  return paths;
}

if (id === undefined || Socials[id] === undefined) return Astro.rewrite("/404");

return Astro.redirect(Socials[id]);
---
