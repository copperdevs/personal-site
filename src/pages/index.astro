---
import QuoteLayout from "../layouts/QuoteLayout.astro";
import favicon from "../assets/favicon.png";
import Blockquote from "../components/Blockquote.astro";
import BlockquoteLink from "../components/BlockquoteLink.astro";
---

<QuoteLayout pageTitle="home" description="home page of my random stuff">
  <Blockquote full={true}>
    <div class="usertitle">
      <img src={favicon.src} alt="Havanese Dog" />
      <h1><a href="https://github.com/copperdevs">copperdevs</a></h1>
    </div>

    <div>
      <h1 class="title">lowkey what do i put here</h1>
    </div>
  </Blockquote>

  <hr />

  <BlockquoteLink href="/projects" noBottomSpacing={true}>
    Projects
  </BlockquoteLink>
  <BlockquoteLink href="/socials" noSpacing={true}> Socials </BlockquoteLink>
  <BlockquoteLink href="/posts" noSpacing={true}> Posts </BlockquoteLink>
</QuoteLayout>
