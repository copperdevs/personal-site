---
interface Props {
  title: string;
  description: string;
  pageTitle: string;
}

const { title, description, pageTitle } = Astro.props;

import ViewTransitions from "astro/components/ViewTransitions.astro";

import Sidebar from "../components/Sidebar.astro";
import Umami from "../components/Umami.astro";
import LinkRedirect from "../components/LinkRedirect.astro";

import { capitalizeFirstLetter } from "../lib/util";

import "../styles/main.css";

const currentPath = Astro.url.pathname;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />

    <link rel="icon" type="image/x-icon" href="/favicon.png" />
    <title>{pageTitle} // {title}</title>

    <ViewTransitions />

    <Umami siteId="bc408a92-1357-4f9b-86ad-5f608ff9e04d" />
  </head>

  <LinkRedirect badUrls={["copperdevs.pages.dev"]} targetUrl="copperdevs.com" />

  <body>
    <div class="content">
      <Sidebar />
      <main>
        <div class="spacer-title" transition:name="main-page-tital">
          <h1 class="no-spacing">
            {capitalizeFirstLetter(pageTitle)}
            <span class="color-lighter-gray">- {currentPath}</span>
          </h1>
          <hr class="limit" />
        </div>
        <slot />
      </main>
    </div>
  </body>
</html>
